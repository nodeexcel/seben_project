# Database
POSTGRES_USER=seben
POSTGRES_PASSWORD=seben_dev_password
POSTGRES_DB=seben_crm
DATABASE_URL=postgresql://seben:seben_dev_password@db:5432/seben_crm

# Backend
SECRET_KEY=change-me-in-production
DEBUG=true
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# OpenAI (optional — for AI summaries in later phases)
OPENAI_API_KEY=

# Upload settings
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# Google Drive invoice sync (Option A — single source, one folder per year)
# Client creates service account under their Gmail and sends you the JSON key.
GOOGLE_DRIVE_CREDENTIALS_JSON=/home/ubuntu/seben_project/secrets/google-drive.json
# Optional default for single-folder sync (sync_drive.py with no args)
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_DRIVE_INVOICE_YEAR=
# All year folders live in config/drive_folders.json — use scripts/sync_all_drive.py
